# Copy to .env and fill in. .env is gitignored — never commit real secrets.

# ---- Portal DB ----
PORTAL_DB_URL=jdbc:mysql://localhost:3306/portal?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
PORTAL_DB_USER=portal
PORTAL_DB_PASSWORD=portalpass

# ---- MySQL root / gitea (used by docker-compose) ----
MYSQL_ROOT_PASSWORD=rootpass
GITEA_DB_PASSWORD=giteapass

# ---- Gitea API (portal enriches commits) ----
GITEA_BASE_URL=http://localhost:3000
GITEA_API_TOKEN=
GITEA_OWNER=

# ---- Shared secret: Jenkins -> portal /api/scan-results ----
PORTAL_API_TOKEN=changeme

# ---- SonarQube Web API (portal pulls vulnerability counts) ----
SONAR_BASE_URL=http://localhost:9000
SONAR_API_TOKEN=

# ---- Jenkins remote build (ops triggers deploy job) ----
JENKINS_BASE_URL=http://localhost:8080
JENKINS_USER=
JENKINS_API_TOKEN=
JENKINS_DEPLOY_JOB=deploy
JENKINS_DEPLOY_TOKEN=

# ---- AI Security Analyst — optional ----
# The analyst uses Claude if ANTHROPIC_API_KEY is set, else Groq (free) if GROQ_API_KEY
# is set. Without either, the Risk Intelligence dashboard still works (threat-intel
# ranking); only the AI explain/fix features are hidden.
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-opus-4-8
# Free, fast alternative — get a key at console.groq.com (no credit card).
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
